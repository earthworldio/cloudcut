# ============================================================
# Copy this file to .env and fill in the values before running docker compose
# cp .env.example .env
# ============================================================

# Public hostname used by Caddy (TLS) and presigned URL generation
# Local:      HOST=localhost  (HTTP only, no TLS)
# Production: HOST=13-239-36-45.sslip.io  (auto TLS via sslip.io)
HOST=localhost

# MinIO credentials — must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET_NAME=cloudcut-assets

# JWT signing secret — change this before deploying to production
JWT_SECRET=change-me-in-production

# Frontend Vite API base URL (baked into the image at build time)
# Use /api for any setup where frontend + backend share the same domain
VITE_API_URL=/api

# Docker image tag — leave commented out to build from source with docker compose build
# TAG=
